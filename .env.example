# Copy this file to .env and set your real values.
# If you see "Internal Server Error" or "Missing Sportmonks API token", the .env file is missing or the token is not set.

# Sportmonks Football API (get one at https://www.sportmonks.com/)
# Used for fixtures, odds, lineups, and recent player match stats (Build Value Bets evidence).
SPORTMONKS_API_TOKEN=your_token_here

# Optional: for odds data
ODDS_API_KEY=your_odds_api_key_here

# Shared login for the whole app (no signup/users table).
APP_LOGIN_USERNAME=your_shared_username
APP_LOGIN_PASSWORD=your_shared_password

# Long random string for cookie session signing (32+ chars recommended).
SESSION_SECRET=replace_with_a_long_random_secret
