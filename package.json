{
  "name": "football-fixture-calendar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:api\" \"vite\"",
    "dev:api": "tsx server/index.ts",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "backtest": "tsx scripts/runBacktest.ts",
    "settle": "tsx scripts/settleBacktestRows.ts",
    "outcomes:generate": "tsx scripts/generateFixtureOutcomes.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.3.0",
    "vite": "^5.4.10"
  }
}
