{
  "name": "football-fixture-calendar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:api\" \"vite\"",
    "dev:api": "tsx server/index.ts",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "backtest": "tsx scripts/runBacktest.ts",
    "settle": "tsx scripts/settleBacktestRows.ts",
    "outcomes:generate": "tsx scripts/generateFixtureOutcomes.ts",
    "backtest:reset-bad-settlements": "tsx scripts/resetBadSettlements.ts",
    "backtest:clean-unsupported": "tsx scripts/cleanUnsupportedBacktestRows.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "express-session": "^1.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "typescript": "^5.3.0",
    "vite": "^5.4.10",
    "vitest": "^4.1.0"
  }
}
